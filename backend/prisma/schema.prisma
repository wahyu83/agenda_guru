generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  username  String     @unique
  password  String
  role      String
  nama      String
  nip       String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  pengampu  Pengampu[]
  kelasWali Kelas[]    @relation("WaliKelas")
}

model TahunPelajaran {
  id       Int     @id @default(autoincrement())
  nama     String
  semester String
  isActive Boolean @default(false)
  kelas    Kelas[]
}

model MataPelajaran {
  id       Int        @id @default(autoincrement())
  nama     String
  pengampu Pengampu[]
}

model Kelas {
  id               Int            @id @default(autoincrement())
  nama             String
  tahunPelajaranId Int
  waliKelasId      Int?
  enrollment       Enrollment[]
  tahunPelajaran   TahunPelajaran @relation(fields: [tahunPelajaranId], references: [id])
  pengampu         Pengampu[]
  waliKelas        User?          @relation("WaliKelas", fields: [waliKelasId], references: [id])
}

model Siswa {
  id         Int            @id @default(autoincrement())
  nis        String         @unique
  nama       String
  absensi    AbsensiSiswa[]
  enrollment Enrollment[]
}

model Enrollment {
  id      Int   @id @default(autoincrement())
  siswaId Int
  kelasId Int
  kelas   Kelas @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  siswa   Siswa @relation(fields: [siswaId], references: [id], onDelete: Cascade)

  @@unique([siswaId, kelasId])
}

model Pengampu {
  id      Int           @id @default(autoincrement())
  guruId  Int
  mapelId Int
  kelasId Int
  hari    String        @default("Senin")
  jamKe   Int           @default(1)
  jamSampai Int         @default(1)
  absensi Absensi[]
  agenda  Agenda[]
  nilai   Nilai[]
  guru    User          @relation(fields: [guruId], references: [id], onDelete: Cascade)
  kelas   Kelas         @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  mapel   MataPelajaran @relation(fields: [mapelId], references: [id], onDelete: Cascade)
}

model Agenda {
  id            Int      @id @default(autoincrement())
  pengampuId    Int
  tanggal       DateTime @db.Date
  materi        String
  deskripsi     String
  catatan       String?
  last_modified DateTime @default(now())
  status_sync   String   @default("synced")
  pengampu      Pengampu @relation(fields: [pengampuId], references: [id], onDelete: Cascade)
}

model Absensi {
  id            Int            @id @default(autoincrement())
  pengampuId    Int
  tanggal       DateTime       @db.Date
  last_modified DateTime       @default(now())
  status_sync   String         @default("synced")
  pengampu      Pengampu       @relation(fields: [pengampuId], references: [id], onDelete: Cascade)
  siswaDetail   AbsensiSiswa[]
}

model AbsensiSiswa {
  id        Int     @id @default(autoincrement())
  absensiId Int
  siswaId   Int
  status    String
  absensi   Absensi @relation(fields: [absensiId], references: [id], onDelete: Cascade)
  siswa     Siswa   @relation(fields: [siswaId], references: [id], onDelete: Cascade)
}

model Nilai {
  id            Int      @id @default(autoincrement())
  pengampuId    Int
  enrollmentId  Int
  siswaId       Int
  jenis         String   @default("tugas")
  nilai         Float
  tanggal       DateTime @db.Date
  deskripsi     String?
  last_modified DateTime @default(now())
  pengampu      Pengampu @relation(fields: [pengampuId], references: [id], onDelete: Cascade)
  enrollment    Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  siswa         Siswa    @relation(fields: [siswaId], references: [id], onDelete: Cascade)
}
